# Copy this file to .env and fill in your real values. The real .env is gitignored.

# DeepXiv token for data.rag.ac.cn — primary path for fetching arxiv paper markdown.
# Used by scripts/batch_import.py. Interactive Claude Code flows use the MCP server,
# which has its own token in ~/.claude.json; this env var is only needed for scripts.
DEEPXIV_TOKEN=

# MinerU cloud API token (JWT) — fallback parser for non-arxiv PDFs.
# Get from https://mineru.net/apiManage/
MINERU_API_TOKEN=

# Optional: arXiv email for polite API usage (arxiv.org asks users identify themselves in UA)
ARXIV_CONTACT_EMAIL=
